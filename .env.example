ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# 观看者：可看项目/需求/待办，不能进密钥索引、项目密钥、备份与 Git 总仓
VIEWER_USERNAME=
VIEWER_PASSWORD=
ADMIN_SESSION_SECRET=dev-secret-change-in-production
REQUIRE_AUTH=false
CRON_SECRET=dev-cron-secret
GITHUB_TOKEN=
# 可选：compare_sources 拉 Vercel production 部署
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
STUDIO_IDEAS_REPO=1Astar/star_project-manage
IDEAS_CAPTURE_SECRET=
STAR_PM_MCP_SECRET=
# ChatGPT 用户自定义 OAuth 客户端 ID（默认 star-pm-gpt）
STAR_PM_OAUTH_CLIENT_ID=star-pm-gpt
# MCP SSE 用 redis:// 协议（Upstash 集成后常有 REDIS_URL 或 UPSTASH_REDIS_URL）
REDIS_URL=
UPSTASH_REDIS_URL=
# Upstash REST（OAuth code/token 存储；Vercel Upstash 集成会注入）
KV_REST_API_URL=
KV_REST_API_TOKEN=


# Notion → Idea Studio 导入
# Token 优先在「设置」页填入并存在浏览器 localStorage；此处仅为可选服务端兜底
NOTION_TOKEN=
# 灵感 / Idea 看板数据库 ID（默认已填你的看板）
NOTION_IDEA_DATABASE_ID=90c63edb-e2ae-4997-ba6d-b7b6c7367f8a
# 项目详情页 ID，逗号分隔（默认 Moonpie / 随心而行）
NOTION_PROJECT_PAGE_IDS=395a86f5-0915-810a-9bf2-da9551d6e782
# 可选：演进记录数据库
NOTION_EVOLUTION_DATABASE_ID=

NEXT_PUBLIC_SUPABASE_URL=https://gwqfrpstgjkwhhxbshkz.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 项目密钥加密主密钥（openssl rand -base64 32）
SECRETS_ENCRYPTION_KEY=
