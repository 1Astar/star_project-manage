{
  "crons": [
    {
      "path": "/api/cron/reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/sync-ideas",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/sync-git",
      "schedule": "0 11 * * *"
    }
  ],
  "functions": {
    "app/api/[transport]/route.ts": {
      "maxDuration": 60
    },
    "app/api/mcp-oauth/[transport]/route.ts": {
      "maxDuration": 60
    }
  }
}
